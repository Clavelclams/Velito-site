# ============================================================
# Velito Compta — variables d'environnement (MODÈLE)
# Copier ce fichier en `.env.local` et remplir les valeurs.
# `.env.local` est ignoré par Git — les secrets ne partent JAMAIS sur GitHub.
# ============================================================
# DÉCISION 06/07/2026 : Compta réutilise le projet Supabase du hub velito.fr
# (pas de projet dédié). Reprendre les mêmes valeurs que le hub.
# ============================================================

# URL du projet Supabase (Dashboard > Settings > API)
# NEXT_PUBLIC_ = accessible côté navigateur. OK ici : ce n'est pas un secret,
# la sécurité repose sur les Row Level Security policies, pas sur le secret de l'URL.
NEXT_PUBLIC_SUPABASE_URL=

# Clé "anon" (publique). Même logique : elle ne donne accès qu'à ce que
# les policies RLS autorisent pour l'utilisateur connecté.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Liste blanche d'accès (OBLIGATOIRE en prod car auth.users est partagé avec
# le hub : tout compte Velito est "authentifié", seuls ces emails sont
# AUTORISÉS à entrer dans Compta). Emails séparés par des virgules.
COMPTA_EMAILS_AUTORISES=

# Clé service_role — UNIQUEMENT côté serveur, JAMAIS de préfixe NEXT_PUBLIC_.
# Elle contourne les RLS : la mettre côté client = donner toute la base.
# On ne la remplit que le jour où on en a réellement besoin (scripts d'admin).
# SUPABASE_SERVICE_ROLE_KEY=
